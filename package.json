{
  "name": "kidlearn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "setup:db": "npx tsx scripts/setup-dynamodb.ts",
    "setup:stripe": "npx tsx scripts/setup-stripe.ts",
    "seed": "curl -s http://localhost:3000/api/seed",
    "seed:questions": "npx tsx scripts/seed-questions.ts",
    "seed:questions:dry": "DRY_RUN=true npx tsx scripts/seed-questions.ts",
    "generate:questions": "npx tsx scripts/generate-question-bank.ts",
    "backfill:difficulty": "npx tsx scripts/backfill-child-difficulty.ts",
    "backfill:difficulty:dry": "npx tsx scripts/backfill-child-difficulty.ts --dry-run",
    "test:setup": "npx tsx scripts/test/setup.ts",
    "test:teardown": "npx tsx scripts/test/teardown.ts",
    "test:tsunami": "npx tsx scripts/test/runner.ts --url http://localhost:3000",
    "test:tsunami:prod": "npx tsx scripts/test/runner.ts",
    "test:unit": "npx tsx scripts/test/runner.ts --suite adaptive --no-setup --no-teardown",
    "process:issues": "npx tsx scripts/process-question-issues.ts",
    "process:issues:dry": "npx tsx scripts/process-question-issues.ts --dry-run",
    "secops:scan": "node scripts/secops/scan-repo.mjs && node scripts/secops/scan-git-history.mjs && node scripts/secops/scan-config.mjs",
    "secops:status": "node scripts/secops/show-status.mjs",
    "secops:remediate": "node scripts/secops/remediate.mjs",
    "secops:remediate:apply": "node scripts/secops/remediate.mjs --apply",
    "agents:status": "node scripts/agents/show-status.mjs",
    "agents:set-task": "node scripts/agents/set-task.mjs",
    "agents:update": "node scripts/agents/update-status.mjs",
    "agents:handoff": "node scripts/agents/post-handoff.mjs",
    "agents:message": "node scripts/agents/post-message.mjs",
    "agents:poll": "node scripts/agents/poll.mjs",
    "agents:graph": "npx tsx scripts/agents/langgraph-orchestrator.ts",
    "agents:graph:write": "npx tsx scripts/agents/langgraph-orchestrator.ts --write",
    "agents:graph:explain": "npx tsx scripts/agents/langgraph-orchestrator.ts --explain",
    "infra:synth": "cdk synth",
    "infra:diff": "cdk diff",
    "infra:deploy": "cdk deploy --require-approval never",
    "infra:bootstrap": "cdk bootstrap"
  },
  "dependencies": {
    "@auth/dynamodb-adapter": "^2.11.1",
    "@aws-sdk/client-bedrock-runtime": "^3.1014.0",
    "@aws-sdk/client-dynamodb": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-secrets-manager": "^3.1014.0",
    "@aws-sdk/client-ses": "^3.1015.0",
    "@aws-sdk/lib-dynamodb": "^3.1014.0",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.6.0",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/source-map-support": "^0.5.10",
    "@types/uuid": "^10.0.0",
    "aws-cdk": "^2.1113.0",
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.6.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "source-map-support": "^0.5.21",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
