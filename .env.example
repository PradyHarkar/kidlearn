# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                        # generate: openssl rand -base64 32

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=                      # use IAM role in production, not keys
AWS_SECRET_ACCESS_KEY=

# ── DynamoDB tables ───────────────────────────────────────────────────────────
DYNAMODB_USERS_TABLE=kidlearn-users
DYNAMODB_CHILDREN_TABLE=kidlearn-children
DYNAMODB_QUESTIONS_TABLE=kidlearn-questions
DYNAMODB_PROGRESS_TABLE=kidlearn-progress
DYNAMODB_ACHIEVEMENTS_TABLE=kidlearn-achievements
DYNAMODB_SESSIONS_TABLE=kidlearn-sessions

# ── AWS Bedrock (AI tutor) ────────────────────────────────────────────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Stripe (subscriptions) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KidLearn

# ── Cron / reports ────────────────────────────────────────────────────────────
CRON_SECRET=                            # shared secret for /api/reports/weekly

# ── Agent coordination (LangGraph / Confluence) ───────────────────────────────
CONFLUENCE_BASE_URL=                    # e.g. https://yourorg.atlassian.net
CONFLUENCE_SPACE_KEY=KidsLearn
CONFLUENCE_API_KEY=                     # Atlassian API token — never commit
